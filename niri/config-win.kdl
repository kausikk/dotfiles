include "shared-config.kdl"

output "DP-1" {
    mode "2560x1440@179.960"
    scale 1
    position x=0 y=0
    variable-refresh-rate on-demand=true
    layout {
        default-column-width { proportion 0.5; }
    }
}

output "DP-2" {
    mode "1366x768@59.790"
    scale 1
    transform "90"
    position x=2560 y=0
}

spawn-at-startup "swww-daemon"

window-rule {
    match app-id="^discord$"
    match app-id="^steam$"
    open-on-output "DP-1"
}
