{
  "terminal": {
    "shell": {
      "program": "cmd.exe",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "file_finder": {
    "modal_max_width": "medium",
    "include_ignored": "all",
  },
  "search": {
    "include_ignored": false,
  },
  "show_wrap_guides": false,
  "file_scan_exclusions": [
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/.sl",
    "**/.repo",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "restore_on_startup": "empty_tab",
  "scroll_beyond_last_line": "off",
  "ssh_connections": [
    {
      "host": "srv01",
      "args": [],
      "projects": [
        {
          "paths": ["/localhome/kka206/bishoy_fhe_acc"],
        },
        {
          "paths": ["/localhome/kka206/damov"],
        },
        {
          "paths": ["/localhome/kka206/mcpat"],
        },
      ],
    },
  ],
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "tabs": {
    "git_status": true,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "completions": {
    "lsp": false,
  },
  "show_completions_on_input": false,
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "enabled": true,
    },
    "include_warnings": false,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
  },
  "minimap": {
    "show": "always",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "icon_theme": "Zed (Default)",
  "ui_font_size": 12,
  "buffer_font_size": 14,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Rosé Pine",
  },
}
