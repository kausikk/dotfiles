[
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space f": "file_finder::Toggle",
      "space /": "pane::DeploySearch",

      // --- Git Operations ---
      "space g c": "editor::ToggleGitBlame",
      "space g g": "pane::ToggleWindowSidebar",
      "space ]": "editor::GoToNextHunk",
      "space [": "editor::GoToPreviousHunk",
      "space g p": "editor::ToggleGitBlame",
      "space g r": "editor::RevertSelectedHunks",

      // --- File Explorer ---
      "space e": "project_panel::ToggleFocus",

      // --- Navigation & Movement ---
      "shift h": "vim::FirstNonWhitespaceCharacter",
      "shift l": "vim::EndOfLine",

      // --- Window Management ---
      "ctrl-h": "window::FocusLeft",
      "ctrl-l": "window::FocusRight",
      "ctrl-j": "window::FocusBottom",
      "ctrl-k": "window::FocusTop",

      // --- Misc ---
      "U": "editor::Redo",
      "alt-o": "editor::SelectLargerSyntaxNode",
      "alt-i": "editor::SelectSmallerSyntaxNode",
    },
  },
]
