[
  {
    "bindings": {
      "space f": "file_finder::Toggle",
      "space e": "project_panel::ToggleFocus",
      "space g g": "git_panel::ToggleFocus",
      "space /": "pane::DeploySearch",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space ]": "editor::GoToHunk",
      "space [": "editor::GoToPreviousHunk",
      "space g p": "editor::ToggleSelectedDiffHunks",
      "space g b": "editor::ToggleGitBlame",
      "space g r": "editor::RevertSelectedHunks",
      "ctrl-w": "pane::CloseActiveItem",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "shift-h": [
        "editor::MoveToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true },
      ],
      "shift-l": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "shift-u": "editor::Redo",
      "alt-o": "editor::SelectLargerSyntaxNode",
      "alt-i": "editor::SelectSmallerSyntaxNode",
    },
  },
]
