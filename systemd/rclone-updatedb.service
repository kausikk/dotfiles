[Unit]
Description=rclone google drive refresh
After=rclone.service
Requires=rclone.service

[Service]
Type=oneshot
User=krkm
Group=krkm
ExecStart=/usr/bin/rclone rc vfs/refresh recursive=true
ExecStart=/usr/bin/updatedb --require-visibility no -o /home/krkm/.cache/gdrive.db -U /mnt/gdrive

[Install]
WantedBy=default.target
