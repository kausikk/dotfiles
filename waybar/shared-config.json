{
    "height": 24,
    "margin-bottom": -12,
    "temperature": {
        "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
        "input-filename": "temp1_input",
        "format": "{temperatureC}°C",
        "tooltip": false,
    },
    "cpu": {
        "format": "{usage:02}%",
    },
    "memory": {
        "format": "{percentage:02}%"
    },
    "tray": {
        "show-passive-items": true,
        "spacing": 12
    },
    "clock": {
        "format": "{:%b %d %I:%M %p}",
        "tooltip": false
    },
}
